# /etc/corporatetraveldc/dispatch-secrets.env.example
# Copy to dispatch-secrets.env and populate before starting services.
# Mode 0600, owned root:corporatetraveldc (readable by service user only).

# ── Anthropic API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Dispatch admin token secret ───────────────────────────────────────────────
DISPATCH_TOKEN_SECRET=<32-char random>

# ── FAA NOTAM API ─────────────────────────────────────────────────────────────
FAA_NOTAM_API_KEY=

# ── ntfy ─────────────────────────────────────────────────────────────────────
NTFY_TOKEN=
NTFY_USER=corey
NTFY_PASS=

# ── Legacy SWIM / FNS (AMQP 1.0 / Proton) — being phased out by FAA ─────────
SWIM_ENABLED=false
# (Legacy AMQP feed vars omitted — use NMS vars below for new provisioning)

# ── FAA SWIM NMS/SCDS (Solace PubSub+) — set after FAA provisioning ──────────
# Request credentials at https://swim.faa.gov / FAA SWIM Program Office
# One set of credentials per VPN (FDPS and STDDS are separate VPNs).

# FDPS feed (SFDPS — flight plan and track data)
SWIM_NMS_USER_FDPS=
SWIM_NMS_PASS_FDPS=
SWIM_NMS_QUEUE_FDPS=

# STDDS feed (surface + terminal tracks, TFRs)
SWIM_NMS_USER_STDDS=
SWIM_NMS_PASS_STDDS=
SWIM_NMS_QUEUE_STDDS=

# TFMS feed (NAS programs: GDP, GS, AFP, AAR — replaces REST nas.py when active)
SWIM_NMS_USER_TFMS=
SWIM_NMS_PASS_TFMS=
SWIM_NMS_QUEUE_TFMS=

# AIM feed (Digital NOTAMs — replaces REST notam.py when active; heartbeat key: fns)
SWIM_NMS_USER_AIM=
SWIM_NMS_PASS_AIM=
SWIM_NMS_QUEUE_AIM=

# TBFM feed (arrival sequencing / meter fix ETAs — no REST fallback)
SWIM_NMS_USER_TBFM=
SWIM_NMS_PASS_TBFM=
SWIM_NMS_QUEUE_TBFM=

# ITWS feed (terminal weather: precip, wind shear, microburst — no REST fallback)
SWIM_NMS_USER_ITWS=
SWIM_NMS_PASS_ITWS=
SWIM_NMS_QUEUE_ITWS=

# ── NWWS-OI (NWS weather push) ────────────────────────────────────────────────
NWWS_JID=<user>@nwws-oi.weather.gov
NWWS_PASSWORD=

# ── FlightAware AeroAPI (optional — enhances watchlist flight status) ─────────
FLIGHTAWARE_API_KEY=
