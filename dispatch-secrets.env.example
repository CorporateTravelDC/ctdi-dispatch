# dispatch-secrets.env -- credentials (mode 0600, never committed)
# Copy this file to /etc/corporatetraveldc/dispatch-secrets.env and populate.

# Anthropic API
ANTHROPIC_API_KEY=

# ntfy auth token
NTFY_TOKEN=

# FAA NOTAM API
FAA_NOTAM_API_KEY=

# SWIM SCDS credentials
SWIM_USERNAME=
SWIM_PASSWORD=

# Airframes.io Jumpseat token (VDL2/ACARS/HFDL fallback when local decoders offline)
AIRFRAMES_JUMPSEAT_TOKEN=

# MarineTraffic API key (AIS fallback when AIS-catcher not running)
MARINETRAFFIC_API_KEY=

# AIS feeder keys (optional -- populate when AIS0162 dongle is active)
AIS_AISHUB_ID=
AIS_MARINETRAFFIC_KEY=
AIS_VESSELFI_KEY=
