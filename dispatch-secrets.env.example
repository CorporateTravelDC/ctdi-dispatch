# dispatch-secrets.env -- credentials (mode 0600, never committed)
# ---------------------------------------------------------------------------
# DO NOT edit this file manually on the Pi.
# Use populate-secrets.sh to write values from ~/.secrets/{name}.{token,key}
#
# Secrets file naming convention:
#   ~/.secrets/ntfy.token         -> NTFY_TOKEN
#   ~/.secrets/faa-notam.token    -> FAA_NOTAM_API_KEY
#   ~/.secrets/acarsdrama.token   -> ACARSDRAMA_JUMPSEAT_TOKEN
#   ~/.secrets/airframes.token    -> AIRFRAMES_TOKEN
#   ~/.secrets/marinetraffic.key  -> MARINETRAFFIC_API_KEY
#   ~/.secrets/aishub.key         -> AIS_AISHUB_ID
#   ~/.secrets/vesselfi.key       -> AIS_VESSELFI_KEY
#
# NOTE: No LLM API key is required for the default local setup.
#       This platform runs inference via Ollama on-device. See dispatch.env for
#       OLLAMA_BASE_URL / OLLAMA_CHAT_MODEL / OLLAMA_OSINT_MODEL.
#
#       Cloud LLM API keys (Anthropic, OpenAI, Google Gemini, etc.) are ONLY
#       needed if you choose to replace Ollama with a cloud provider — that
#       is an opt-in deviation from the intended architecture.
#
# For signup instructions and email templates for every source below, see:
#   docs/DATA_SOURCES.md
# For regional equivalents (European/Asia-Pacific feeds), see:
#   docs/REGIONALIZATION.md
#
# Run: bash populate-secrets.sh
# ---------------------------------------------------------------------------


# =============================================================================
# CORE (required for basic operation)
# =============================================================================

# ntfy auth token
# Self-hosted ntfy — generate with: ntfy user add --role=admin <user>
NTFY_TOKEN=

# FAA NOTAM API
# Sign up: https://api.faa.gov/signup  (self-serve, immediate)
FAA_NOTAM_API_KEY=


# =============================================================================
# FAA SWIM / NMS (US push-primary aviation feeds)
# Sign up: https://portal.swim.faa.gov/
# Docs: https://www.faa.gov/air_traffic/technology/swim/
# Email template: docs/DATA_SOURCES.md
# Each feed gets its own set of NMS credentials.
# =============================================================================

# SWIM SCDS (legacy poller fallback)
SWIM_USERNAME=
SWIM_PASSWORD=

# FDPS — Flight plan + track data
SWIM_NMS_USER_FDPS=
SWIM_NMS_PASS_FDPS=
SWIM_NMS_QUEUE_FDPS=

# STDDS — Surface + terminal tracks, TFRs
SWIM_NMS_USER_STDDS=
SWIM_NMS_PASS_STDDS=
SWIM_NMS_QUEUE_STDDS=

# TFMS — NAS programs (GDP, GS, AFP, AAR)
SWIM_NMS_USER_TFMS=
SWIM_NMS_PASS_TFMS=
SWIM_NMS_QUEUE_TFMS=

# AIM — Digital NOTAMs
SWIM_NMS_USER_AIM=
SWIM_NMS_PASS_AIM=
SWIM_NMS_QUEUE_AIM=

# TBFM — Arrival sequencing / meter fix ETAs
SWIM_NMS_USER_TBFM=
SWIM_NMS_PASS_TBFM=
SWIM_NMS_QUEUE_TBFM=

# ITWS — Terminal weather (precip, wind shear, microburst)
SWIM_NMS_USER_ITWS=
SWIM_NMS_PASS_ITWS=
SWIM_NMS_QUEUE_ITWS=


# =============================================================================
# NWS NWWS-OI (US push weather products — XMPP feed)
# Sign up: https://www.weather.gov/nwws/
# Email template: docs/DATA_SOURCES.md
# Filter WFOs in dispatch.env: NWWS_WFO_FILTER=LWX,AKQ,CTP
# =============================================================================

NWWS_JID=
NWWS_PASSWORD=


# =============================================================================
# FLIGHT TRACKING — commercial aggregators (optional; airplanes.live used free)
# =============================================================================

# FlightAware AeroAPI — premium tracking + historical data + OOOI timestamps
# Sign up: https://flightaware.com/aeroapi/
FLIGHTAWARE_API_KEY=

# acarsdrama Jumpseat — ACARS supplemental feed
# Portal: https://acarsdrama.com/
ACARSDRAMA_JUMPSEAT_TOKEN=

# airframes.io — secondary ACARS fallback
AIRFRAMES_TOKEN=


# =============================================================================
# MARITIME (AIS feeds — active when AIS dongle is running)
# =============================================================================

MARINETRAFFIC_API_KEY=
AIS_AISHUB_ID=
AIS_MARINETRAFFIC_KEY=
AIS_VESSELFI_KEY=


# =============================================================================
# EUROPEAN FEEDS (for deployments operating in European airspace)
# See docs/DATA_SOURCES.md and docs/REGIONALIZATION.md for full details.
# =============================================================================

# EUROCONTROL NM B2B — flight plans, ATFM flow measures, OPMET, NOTAMs
# Access request: https://www.eurocontrol.int/contact/nm-b2b-access-request
# Portal: https://www.eurocontrol.int/service/network-manager-business-business-b2b-web-services
# Email template: docs/DATA_SOURCES.md
EUROCONTROL_NM_B2B_USER=
EUROCONTROL_NM_B2B_PASS=
EUROCONTROL_NM_B2B_CERT_PATH=

# Météo-France open data API
# Sign up: https://portail-api.meteofrance.fr/  (self-serve, immediate)
METEOFRANCE_API_KEY=


# =============================================================================
# JAPAN / ASIA-PACIFIC FEEDS
# See docs/DATA_SOURCES.md and docs/REGIONALIZATION.md for full details.
# =============================================================================

# JASDAT — Japan AIS (NOTAMs, SIGMET, airspace; JCAB/MLIT)
# Portal: https://www.jasdat.go.jp/en/
# Access requires JCAB authorization — email template: docs/DATA_SOURCES.md
JASDAT_USER=
JASDAT_PASS=

# JMA (Japan Meteorological Agency) — open data, registration for some products
# Portal: https://opendata.jma.go.jp/gpv/
# API docs: https://www.data.jma.go.jp/developer/index.html
JMA_API_KEY=

# KMA (Korea Meteorological Administration)
# Sign up: https://apihub.kma.go.kr/  (self-serve)
KMA_API_KEY=

# Airservices Australia NAIPS — NOTAMs, PIREPs, MET reports
# Portal: https://www.airservicesaustralia.com/
# Email template: docs/DATA_SOURCES.md
NAIPS_USER=
NAIPS_PASS=

# CMA (China Meteorological Administration)
# Portal: https://data.cma.cn/  (registration required; limited international access)
CMA_API_KEY=


# =============================================================================
# Cloud LLM API keys (OPTIONAL — not needed for local Ollama setup)
# Uncomment and populate ONLY if replacing Ollama with a cloud provider.
# Requires additional provider wiring in src/runner/main.py.
# =============================================================================

# Anthropic (Claude):
# ANTHROPIC_API_KEY=

# OpenAI (ChatGPT / GPT-4):
# OPENAI_API_KEY=

# Google Gemini:
# GOOGLE_API_KEY=
