# dispatch-secrets.env -- credentials (mode 0600, never committed)
# ---------------------------------------------------------------------------
# DO NOT edit this file manually on the Pi.
# Use populate-secrets.sh to write values from ~/.secrets/{name}.{token,key}
#
# Secrets file naming convention:
#   ~/.secrets/acarsdrama.token   -> ACARSDRAMA_JUMPSEAT_TOKEN
#   ~/.secrets/airframes.token    -> AIRFRAMES_TOKEN
#   ~/.secrets/marinetraffic.key  -> MARINETRAFFIC_API_KEY
#   ~/.secrets/faa-notam.token    -> FAA_NOTAM_API_KEY
#   ~/.secrets/ntfy.token         -> NTFY_TOKEN
#   ~/.secrets/aishub.key         -> AIS_AISHUB_ID
#   ~/.secrets/vesselfi.key       -> AIS_VESSELFI_KEY
#
# NOTE: No LLM API key required. All inference runs locally via Ollama.
#       See dispatch.env for OLLAMA_CHAT_MODEL / OLLAMA_OSINT_MODEL config.
#
# Run: bash populate-secrets.sh
# ---------------------------------------------------------------------------


# ntfy auth token
NTFY_TOKEN=

# FAA NOTAM API
FAA_NOTAM_API_KEY=

# SWIM SCDS credentials
SWIM_USERNAME=
SWIM_PASSWORD=

# acarsdrama Jumpseat token (primary external fallback)
# Endpoint: https://api.jumpseat.acarsdrama.com/v1/messages/search
# Auth: Authorization: Bearer sk_adjs_...
ACARSDRAMA_JUMPSEAT_TOKEN=

# airframes.io token (secondary external fallback -- used only if acarsdrama unavailable)
AIRFRAMES_TOKEN=

# MarineTraffic API key (AIS fallback when AIS-catcher not running)
MARINETRAFFIC_API_KEY=

# AIS feeder keys (optional -- populate when AIS0162 dongle is active)
AIS_AISHUB_ID=
AIS_MARINETRAFFIC_KEY=
AIS_VESSELFI_KEY=