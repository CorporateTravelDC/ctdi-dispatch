# /etc/corporatetraveldc/dispatch.env
# Non-secret runtime configuration. Secrets go in dispatch-secrets.env (mode 0600).

# ââ Database / state ââââââââââââââââââââââââââââââââââââââââââââââââââââââââââ
DISPATCH_DB=/var/lib/corporatetraveldc/corporatetraveldc.db
DISPATCH_STATE_DIR=/var/lib/corporatetraveldc
DISPATCH_TRIGGER_DIR=/run/corporatetraveldc/triggers

# ââ ntfy (port 2586 per ntfy.container) ââââââââââââââââââââââââââââââââââââââ
NTFY_URL=CHANGE_ME

# ââ FAA SWIM NMS/SCDS (Solace PubSub+) âââââââââââââââââââââââââââââââââââââââ
SWIM_NMS_HOST=CHANGE_ME
SWIM_NMS_VPN_FDPS=CHANGE_ME
SWIM_NMS_VPN_STDDS=CHANGE_ME
SWIM_NMS_VPN_TFMS=CHANGE_ME
SWIM_NMS_VPN_AIM=CHANGE_ME
SWIM_NMS_VPN_TBFM=CHANGE_ME
SWIM_NMS_VPN_ITWS=CHANGE_ME

# ââ NWWS-OI (NWS weather push via XMPP) ââââââââââââââââââââââââââââââââââââââ
NWWS_ENABLED=true
NWWS_XMPP_SERVER=CHANGE_ME
NWWS_XMPP_PORT=5222
NWWS_MUC=CHANGE_ME
NWWS_NICK=CHANGE_ME
# WFO filter â keep only DC-area offices; empty = all
NWWS_WFO_FILTER=CHANGE_ME

# ââ Local ADS-B (UltraFeeder) ââââââââââââââââââââââââââââââââââââââââââââââââ
ULTRAFEEDER_URL=CHANGE_ME
ULTRAFEEDER_LAT=CHANGE_ME
ULTRAFEEDER_LON=CHANGE_ME
ULTRAFEEDER_SCAN_RADIUS_NM=30

# ââ ACARS (VHF router) âââââââââââââââââââââââââââââââââââââââââââââââââââââââ
ACARS_ROUTER_HOST=CHANGE_ME
ACARS_ROUTER_PORT=9080

# ââ Tailscale ââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââ
TAILSCALE_DOMAIN_SUFFIX=CHANGE_ME

# ââ Web API âââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââ
DISPATCH_WEB_HOST=0.0.0.0
DISPATCH_WEB_PORT=8000

# -- Local LLM (Ollama) -------------------------------------------------------
# Skills use an Ollama-first / Anthropic-fallback inference chain (src/common/llm.py).
#
# Priority:
#   1. Ollama  — if OLLAMA_BASE_URL is set and reachable, it is used first.
#   2. Anthropic — if Ollama is unreachable or fails, falls back automatically
#                  to claude-haiku via ANTHROPIC_API_KEY (dispatch-secrets.env).
#   3. Deterministic — if both fail, each skill has its own rule-based fallback.
#
# Set OLLAMA_BASE_URL to wherever `ollama serve` is listening:
#   Same host (bare Python):     http://127.0.0.1:11434
#   Container network (Quadlet): http://host.containers.internal:11434
#   Remote host (Pi/Mac/Win):    http://<host-ip>:11434
#
# Set the model names to any models you have pulled in your Ollama instance.
# Custom Modelfiles can be built with build-models.sh (see Modelfile.*.template).
# Common open-weight starting points are shown in the commented examples below.
#
OLLAMA_BASE_URL=http://host.containers.internal:11434
OLLAMA_CHAT_MODEL=CHANGE_TO_YOUR_MODEL   # e.g. llama3.2:3b, mistral, phi3:mini
OLLAMA_OSINT_MODEL=CHANGE_TO_YOUR_MODEL  # e.g. mistral, llama3.1:8b, phi3:medium
