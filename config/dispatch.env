# /etc/corporatetraveldc/dispatch.env
# Non-secret runtime configuration. Secrets go in dispatch-secrets.env (mode 0600).

# 芒聰聙芒聰聙 Database / state 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
DISPATCH_DB=/var/lib/corporatetraveldc/corporatetraveldc.db
DISPATCH_STATE_DIR=/var/lib/corporatetraveldc
DISPATCH_TRIGGER_DIR=/run/corporatetraveldc/triggers

# 芒聰聙芒聰聙 ntfy (port 2586 per ntfy.container) 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
NTFY_URL=http://host.containers.internal:2586

# 芒聰聙芒聰聙 FAA SWIM NMS/SCDS (Solace PubSub+) 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
SWIM_NMS_HOST=tcps://ems2.swim.faa.gov:55443
SWIM_NMS_VPN_FDPS=FDPS
SWIM_NMS_VPN_STDDS=STDDS
SWIM_NMS_VPN_TFMS=TFMS
SWIM_NMS_VPN_AIM=AIM
SWIM_NMS_VPN_TBFM=TBFM
SWIM_NMS_VPN_ITWS=ITWS

# 芒聰聙芒聰聙 NWWS-OI (NWS weather push via XMPP) 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
NWWS_ENABLED=true
NWWS_XMPP_SERVER=nwws-oi.weather.gov
NWWS_XMPP_PORT=5222
NWWS_MUC=nwws@conference.nwws-oi.weather.gov
NWWS_NICK=corporatetraveldc
# WFO filter 芒聙聰 keep only DC-area offices; empty = all
NWWS_WFO_FILTER=LWX,AKQ,CTP,PHI

# 芒聰聙芒聰聙 Local ADS-B (UltraFeeder) 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
ULTRAFEEDER_URL=http://host.containers.internal:8080
ULTRAFEEDER_LAT=38.8512
ULTRAFEEDER_LON=-77.0402
ULTRAFEEDER_SCAN_RADIUS_NM=30

# 芒聰聙芒聰聙 ACARS (VHF router) 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
ACARS_ROUTER_HOST=host.containers.internal
ACARS_ROUTER_PORT=9080

# 芒聰聙芒聰聙 Tailscale 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
TAILSCALE_DOMAIN_SUFFIX=.csexecutiveservices.ts.net

# 芒聰聙芒聰聙 Web API 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙
DISPATCH_WEB_HOST=0.0.0.0
DISPATCH_WEB_PORT=8000

# -- Local LLM (Ollama) -------------------------------------------------------
# This platform is designed for LOCAL inference via Ollama. No cloud LLM API
# key is required for normal operation. Set OLLAMA_BASE_URL to wherever
# ollama serve is listening:
#   Same host (bare Python):     http://127.0.0.1:11434
#   Container network (Quadlet): http://host.containers.internal:11434
#   Remote host (Pi/Mac/Win):    http://<host-ip>:11434
#
# To use a cloud LLM (Anthropic, OpenAI, Gemini, etc.) INSTEAD of local Ollama,
# add the provider API key to dispatch-secrets.env and wire the provider into
# src/runner/main.py. That is an opt-in deviation from the default local setup.
#
OLLAMA_BASE_URL=http://host.containers.internal:11434
OLLAMA_CHAT_MODEL=csexec-chat        # custom model from build-models.sh
OLLAMA_OSINT_MODEL=csexec-osint      # custom model from build-models.sh
# Fallback base models if custom models not yet built:
# OLLAMA_CHAT_MODEL=llama3.2:3b
# OLLAMA_OSINT_MODEL=mistral

# -- Amtrak (Amtraker v3) -----------------------------------------------------
# Amtraker v3 is a community-maintained proxy for Amtrak's Track-A-Train data.
# Free, no credentials required. No AMTRAK_* vars are strictly required --
# all have sensible defaults for a DC/NEC operator.
#
# AMTRAK_FEED_URL          : Amtraker v3 trains endpoint. Default is correct.
#                            Only change if self-hosting a local Amtraker instance.
AMTRAK_FEED_URL=https://api.amtraker.com/v3/trains
AMTRAKER_API_URL=https://api.amtraker.com/v3
#
# AMTRAK_PRIMARY_STATION   : The operator's hub station. Used for map centering
#                            and as the default fallback for all station filters.
#                            One station code only. See: https://www.amtrak.com/stations
AMTRAK_PRIMARY_STATION=WAS
#
# AMTRAK_REGIONAL_STATIONS : Comma-separated station codes. Any train that stops
#                            at ANY of these stations is included in the ops brief
#                            and delay summary. Use this for the broad regional net --
#                            trains that pass through your area even if they don't
#                            serve your primary hub directly.
#                            Example (DC/NEC corridor):
AMTRAK_REGIONAL_STATIONS=WAS,BAL,WIL,PHL,TRE,NYP,NHV,NLC,BOS
#
# AMTRAK_WATCHLIST_STATIONS: Comma-separated station codes for per-train alerts.
#                            These are the specific stations you actively monitor
#                            for client pickups/dropoffs. Trains serving ANY of
#                            these stations trigger watchlist-level alerting and
#                            are flagged [WATCH] in delay summaries.
#                            Narrower than REGIONAL -- typically just the stations
#                            where you physically meet clients.
#                            Defaults to AMTRAK_PRIMARY_STATION only if unset.
AMTRAK_WATCHLIST_STATIONS=WAS,BWI,NCR,ALX
#
# AMTRAK_CORE_ROUTES        : Routes that always appear in the ops brief top section.
#                             These are your bread-and-butter services.
AMTRAK_CORE_ROUTES=Acela,Northeast Regional
#
# AMTRAK_POLL_INTERVAL_SECS : How often the ingest container polls Amtraker.
#                             Default 300 (5 min). Amtraker updates every ~2 min
#                             so polling faster than 120 is not useful.
AMTRAK_POLL_INTERVAL_SECS=300
