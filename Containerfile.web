FROM python:3.13-slim

LABEL org.opencontainers.image.title="corporatetraveldc-web" \
      org.opencontainers.image.description="Corporate Travel DC Dispatch — FastAPI web service"

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt

COPY src/ .

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

CMD ["uvicorn", "web.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--proxy-headers", \
     "--forwarded-allow-ips=*", \
     "--log-level", "info"]
