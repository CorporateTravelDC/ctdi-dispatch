# ~/.config/containers/systemd/openwebui.container
#
# OpenWebUI -- browser-based Ollama chat UI
#
# Access:
#   Tailscale: http://100.94.80.100:3000
#   CF tunnel: https://openwebui.csexecutiveservices.com
#
# Ollama backend: http://127.0.0.1:11434 (loopback, never public)

[Unit]
Description=OpenWebUI -- Ollama browser interface
After=ollama.service network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/open-webui/open-webui:main
ContainerName=openwebui
AutoUpdate=registry
PublishPort=3000:8080
Volume=/var/lib/openwebui:/app/backend/data:Z
Environment=OLLAMA_BASE_URL=http://host.containers.internal:11434
NoNewPrivileges=true

[Service]
Restart=always
RestartSec=10
TimeoutStartSec=300

[Install]
WantedBy=default.target
