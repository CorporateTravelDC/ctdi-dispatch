FROM python:3.13-slim

LABEL org.opencontainers.image.title="corporatetraveldc-amtrak-tracker" \
      org.opencontainers.image.description="Corporate Travel DC — Amtrak NEC push-primary tracker"

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt

COPY src/ .

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

CMD ["python3", "-m", "amtrak_tracker.main"]
